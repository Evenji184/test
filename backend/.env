# 环境变量配置
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
PUBLIC_HOST=172.21.38.119

# MySQL数据库配置，DB_USER=evenji和DB_PASSWORD=evenji的值为安装数据库时设置的用户，非root用户
DB_HOST=localhost
DB_PORT=3306
DB_FAMILY=
DB_NAME=file_share_db
DB_USER=evenji
DB_PASSWORD=evenji
DB_SYNC_ALTER=false

# JWT配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=7d

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS配置（可填写多个前端地址，使用英文逗号分隔）
CLIENT_URL=http://172.21.38.119:3000,http://localhost:3000,http://127.0.0.1:3000,http://192.168.3.151:3000

# HTTPS配置（可选，开发环境建议关闭）
HTTPS_ENABLED=false
HTTPS_KEY_PATH=./certs/localhost-key.pem
HTTPS_CERT_PATH=./certs/localhost-cert.pem

# 默认管理员配置
DEFAULT_ADMIN_PASSWORD=admin123456
DEFAULT_ADMIN_EMAIL=evenji@example.com
